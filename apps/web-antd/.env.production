VITE_BASE=/

# ---------- 生产/发布打包用：默认走同源 /api，由 IIS/Nginx 反向代理到 StoneApi ----------
# 这样浏览器只访问当前站点，避免把 127.0.0.1 或内网端口打包进前端产物。
VITE_GLOB_API_URL=/api
VITE_GLOB_BACKEND_URL=/api

# 前端请求超时（毫秒）；服务器较慢可适当调大
VITE_HTTP_TIMEOUT_MS=180000

# 是否开启压缩，可以设置为 none, brotli, gzip
VITE_COMPRESS=none

# 是否开启 PWA
VITE_PWA=false

# vue-router 的模式
VITE_ROUTER_HISTORY=hash

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true

# 打包后是否生成dist.zip
VITE_ARCHIVER=true
